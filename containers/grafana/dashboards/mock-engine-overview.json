{
  "uid": "mock-engine-overview",
  "title": "Mock Engine API - Overview",
  "tags": ["mock-engine", "observability"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests/sec",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(sum(rate(http_requests_total{schema!=\"unknown\",endpoint!=\"/metrics/\"}[1m])))",
          "legendFormat": "Requests/sec",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
    },
    {
      "id": 20,
      "title": "Data Generation Rate (AVG)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(items_generated_total[1m]))",
          "legendFormat": "Items/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
    },
    {
      "id": 2,
      "title": "Items Generated (Total)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(items_generated_total)",
          "legendFormat": "Total Items",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
    },
    {
      "id": 3,
      "title": "Avg Request Duration",
      "type": "stat",
      "targets": [
        {
          "expr": "(rate(http_request_duration_seconds_sum{schema!=\"unknown\",endpoint!=\"/metrics/\"}[1m]) / rate(http_request_duration_seconds_count{schema!=\"unknown\",endpoint!=\"/metrics/\"}[1m])) * 1000",
          "legendFormat": "Avg Duration",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0}
    },
    {
      "id": 23,
      "title": "Data Generation Over Time",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(items_generated_total[1m])",
          "legendFormat": "{{schema}}",
          "refId": "A"
        }
      ],
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "pointradius": 2,
      "points": false,
      "renderer": "flot",
      "spaceLength": 10,
      "stack": false,
      "steppedLine": false,
      "bars": false,
      "dashLength": 10,
      "dashes": false,
      "nullPointMode": "null",
      "percentage": false,
      "aliasColors": {},
      "seriesOverrides": [],
      "legend": {
        "show": true,
        "values": false,
        "min": false,
        "max": false,
        "current": false,
        "total": false,
        "avg": false,
        "alignAsTable": false,
        "rightSide": false
      },
      "tooltip": {
        "shared": true,
        "sort": 0,
        "value_type": "individual"
      },
      "xaxis": {
        "show": true,
        "mode": "time",
        "name": null,
        "values": [],
        "buckets": null
      },
      "yaxes": [
        {
          "show": true,
          "format": "ops",
          "label": "Items/sec",
          "logBase": 1,
          "min": null,
          "max": null,
          "decimals": null
        },
        {
          "show": false,
          "format": "short",
          "logBase": 1,
          "min": null,
          "max": null,
          "decimals": null
        }
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4}
