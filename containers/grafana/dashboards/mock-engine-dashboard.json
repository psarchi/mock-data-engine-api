{
  "title": "Mock Data Engine - Overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 0,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "API Traffic (REST + Streaming)",
      "type": "graph",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 16,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "Request Rate ({{endpoint}})",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p50 Latency",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p95 Latency",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p99 Latency",
          "refId": "D"
        },
        {
          "expr": "rate(http_requests_total{status_code=~\"5..\"}[1m]) / rate(http_requests_total[1m]) * 100",
          "legendFormat": "Error Rate %",
          "refId": "E"
        },
        {
          "expr": "sum(websocket_active_connections)",
          "legendFormat": "Active Connections",
          "refId": "F"
        }
      ],
      "yaxes": [
        {
          "label": "Rate / Connections",
          "show": true,
          "min": 0
        },
        {
          "label": "Latency (s) / Error %",
          "show": true,
          "min": 0
        }
      ],
      "xaxis": {
        "show": true,
        "mode": "time"
      },
      "legend": {
        "show": true,
        "alignAsTable": true,
        "rightSide": false,
        "values": true,
        "current": true,
        "max": true,
        "min": true,
        "avg": true
      },
      "tooltip": {
        "shared": true,
        "sort": 0,
        "value_type": "individual"
      }
    },
    {
      "id": 2,
      "title": "Generator Performance",
      "type": "graph",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(generator_duration_seconds_bucket[1m])) * 1000",
          "legendFormat": "p50 (ms) - {{generator}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(generator_duration_seconds_bucket[1m])) * 1000",
          "legendFormat": "p95 (ms) - {{generator}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(generator_duration_seconds_bucket[1m])) * 1000",
          "legendFormat": "p99 (ms) - {{generator}}",
          "refId": "C"
        },
        {
          "expr": "rate(generator_invocations_total[1m])",
          "legendFormat": "Invocations/s - {{generator}}",
          "refId": "D"
        }
      ],
      "yaxes": [
        {
          "label": "Duration (ms)",
          "show": true,
          "min": 0
        },
        {
          "label": "Invocations/s",
          "show": true,
          "min": 0
        }
      ],
      "legend": {
        "show": true,
        "alignAsTable": true,
        "values": true,
        "current": true,
        "max": true,
        "avg": true
      }
    },
    {
      "id": 3,
      "title": "Chaos Operations",
      "type": "graph",
      "gridPos": {
        "x": 8,
        "y": 8,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(chaos_active_operations) by (op)",
          "legendFormat": "Active: {{op}}",
          "refId": "A"
        },
        {
          "expr": "rate(chaos_op_executions_total{applied=\"true\"}[1m])",
          "legendFormat": "Rate: {{op}}",
          "refId": "B"
        },
        {
          "expr": "rate(chaos_items_affected_total[1m])",
          "legendFormat": "Items Affected/s: {{op}}",
          "refId": "C"
        }
      ],
      "yaxes": [
        {
          "label": "Count / Rate",
          "show": true,
          "min": 0
        }
      ],
      "legend": {
        "show": true,
        "alignAsTable": true,
        "values": true,
        "current": true
      }
    },
    {
      "id": 10,
      "title": "Configuration Status",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 16
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "orientation": "vertical",
        "textMode": "value_and_name",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "config_enabled{config_key=\"pregeneration_enabled\"}",
          "legendFormat": "Pregen",
          "refId": "A"
        },
        {
          "expr": "config_enabled{config_key=\"chaos_enabled\"}",
          "legendFormat": "Chaos",
          "refId": "B"
        },
        {
          "expr": "config_enabled{config_key=\"logging_enabled\"}",
          "legendFormat": "Logging",
          "refId": "C"
