    {
      "id": 4,
      "title": "Database & Redis Memory Usage",
      "type": "graph",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(persistence_redis_cache_size_mb) by (schema)",
          "legendFormat": "Redis: {{schema}}",
          "refId": "A"
        },
        {
          "expr": "sum(persistence_postgres_cache_size_mb) by (schema)",
          "legendFormat": "PostgreSQL: {{schema}}",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "label": "Memory (MB)",
          "show": true,
          "min": 0
        }
      ],
      "legend": {
        "show": true,
        "alignAsTable": true,
        "values": true,
        "current": true,
        "max": true,
        "avg": true
      }
    },
    {
      "id": 5,
      "title": "Pre-generation Queue Sizes",
      "type": "graph",
      "gridPos": {
        "x": 8,
        "y": 16,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "pregen_queue_size",
          "legendFormat": "{{schema}}",
          "refId": "A"
        },
        {
          "expr": "pregen_generation_rate",
          "legendFormat": "Gen Rate: {{schema}}",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "label": "Queue Size / Items/s",
          "show": true,
          "min": 0
        }
      ],
      "legend": {
        "show": true,
        "alignAsTable": true,
        "values": true,
        "current": true,
        "max": true,
        "avg": true
      }
    },
    {
      "id": 6,
      "title": "Worker Status & Queue Fill Rate",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 16,
        "h": 8
      },
      "targets": [
        {
          "expr": "pregen_queue_size",
          "legendFormat": "{{schema}}",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "pregen_generation_rate",
          "legendFormat": "{{schema}}",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "expr": "rate(items_generated_total{source=\"pregen\"}[1m])",
          "legendFormat": "{{schema}}",
          "refId": "C",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "schema": "Schema",
              "Value #A": "Queue Size",
              "Value #B": "Gen Rate (items/s)",
              "Value #C": "Items Generated/s"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Queue Size",
            "desc": true
          }
        ]
      }
