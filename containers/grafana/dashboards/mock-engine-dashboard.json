        {
          "expr": "config_enabled{config_key=\"metadata_enabled\"}",
          "legendFormat": "Metadata",
          "refId": "D"
        },
        {
          "expr": "config_enabled{config_key=\"observability_enabled\"}",
          "legendFormat": "Observability",
          "refId": "E"
        },
        {
          "expr": "config_enabled{config_key=\"per_generator_metrics_enabled\"}",
          "legendFormat": "Gen Metrics",
          "refId": "F"
