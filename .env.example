# This is mainly used with make up where env is created by scripts/gen_env.py
# if you don't want to mess with the config/default/*.yamls then please use: make up WITHOUT_ENV=true
# Server Configuration
DEBUG=false
PORT=8000
WORKERS=8

# Observability
OBSERVABILITY_LOGGING_ENABLED=true
OBSERVABILITY_LOGGING_LEVEL=INFO
OBSERVABILITY_LOGGING_FORMAT=json
OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_PROMETHEUS_PATH=/metrics
OBSERVABILITY_PROMETHEUS_PORT=9090
OBSERVABILITY_GRAFANA_PORT=3000
OBSERVABILITY_GRAFANA_ADMIN_USER=admin
OBSERVABILITY_GRAFANA_ADMIN_PASSWORD=<your_grafana_admin_password>
OBSERVABILITY_GRAFANA_ALLOW_SIGN_UP=false
OBSERVABILITY_OTEL_ENABLED=false
OBSERVABILITY_OTEL_EXPORTER_OTLP_ENDPOINT=

# Admin
ADMIN_ENABLED=true
ADMIN_ALLOW_UPLOAD=false
ADMIN_STORAGE_PATH=./.admin-store

# GraphQL
GRAPHQL_ENABLED=false

# Security
SECURITY_MODE=none
SECURITY_ALLOWED_ROLES=admin,dev,read
SECURITY_PII_MODE=passthrough

# Sinks
SINKS_ENABLED=false
SINKS_OUTPUTS=

# DLQ (Dead Letter Queue)
DLQ_ENABLED=false
DLQ_STORAGE_PATH=./.dlq
DLQ_SIMULATE_EXACTLY_ONCE=false

# Persistence - General
PERSISTENCE_ENABLED=true
PERSISTENCE_PERSIST_BY_DEFAULT=true

# Persistence - Redis
PERSISTENCE_REDIS_PORT=6379
PERSISTENCE_REDIS_URL=redis://redis:6379
PERSISTENCE_REDIS_KEY_PREFIX=data:
PERSISTENCE_REDIS_TTL_HOURS=24
PERSISTENCE_REDIS_MAXMEMORY=10gb
PERSISTENCE_REDIS_MAXMEMORY_POLICY=allkeys-lru
PERSISTENCE_REDIS_CONNECTION_POOL_MAX_CONNECTIONS=50
PERSISTENCE_REDIS_CONNECTION_POOL_TIMEOUT_SECONDS=5

# Persistence - PostgreSQL
PERSISTENCE_POSTGRES_PORT=5432
PERSISTENCE_POSTGRES_DB=mock_engine
PERSISTENCE_POSTGRES_USER=mock_user
PERSISTENCE_POSTGRES_PASSWORD=<your_postgres_password>
PERSISTENCE_POSTGRES_URL=postgresql://mock_user:<your_postgres_password>@postgres:5432/mock_engine
PERSISTENCE_POSTGRES_RETENTION_DAYS=30
PERSISTENCE_POSTGRES_CONNECTION_POOL_MIN_SIZE=5
PERSISTENCE_POSTGRES_CONNECTION_POOL_MAX_SIZE=20
PERSISTENCE_POSTGRES_CONNECTION_POOL_TIMEOUT_SECONDS=30
PERSISTENCE_POSTGRES_CLEANUP_ENABLED=false
PERSISTENCE_POSTGRES_CLEANUP_RETENTION_DAYS=7
PERSISTENCE_POSTGRES_CLEANUP_INTERVAL_HOURS=24

# Persistence - Batch Sync
PERSISTENCE_BATCH_SYNC_ENABLED=true
PERSISTENCE_BATCH_SYNC_DRAIN_MODE=true
PERSISTENCE_BATCH_SYNC_INTERVAL_SECONDS=3
PERSISTENCE_BATCH_SYNC_BATCH_LIMIT=1000
PERSISTENCE_BATCH_SYNC_METRICS_PORT=8001
PERSISTENCE_BATCH_SYNC_RETRY_MAX_ATTEMPTS=3
PERSISTENCE_BATCH_SYNC_RETRY_BACKOFF_SECONDS=5
PERSISTENCE_BATCH_SYNC_HEALTH_CHECK_ENABLED=true
PERSISTENCE_BATCH_SYNC_HEALTH_CHECK_INTERVAL_SECONDS=60

# Persistence - Metrics Collector
PERSISTENCE_METRICS_COLLECTOR_ENABLED=true
PERSISTENCE_METRICS_COLLECTOR_INTERVAL_SECONDS=30
PERSISTENCE_METRICS_COLLECTOR_METRICS_PORT=8003
PERSISTENCE_METRICS_COLLECTOR_HEALTH_CHECK_ENABLED=true
PERSISTENCE_METRICS_COLLECTOR_HEALTH_CHECK_INTERVAL_SECONDS=60

# Pregeneration
# Leave empty to use config/default/generation.yaml value, or override with comma-separated schema names
PREGENERATION_SCHEMAS=
